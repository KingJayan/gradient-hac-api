{
  "expo": {
    "name": "Gradient",
    "slug": "gradient-hac",
    "version": "1.0.0",
    "orientation": "portrait",
    "owner": "kingjayan",
    "runtimeVersion": "1.0.0",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#10B981"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.kingjayan.gradient",
      "buildNumber": "1",
      "deploymentTarget": "14.0",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera access is required for profile photos",
        "NSPhotoLibraryUsageDescription": "Photo library access is required for profile pictures",
        "NSLocationWhenInUseUsageDescription": "Location access is optional for school location display",
        "NSBonjourServiceTypes": ["_http._tcp"],
        "NSLocalNetworkUsageDescription": "Local network usage for app functionality",
        "UIBackgroundModes": ["fetch"],
        "ITSAppUsesNonExemptEncryption": false
      },
      "userInterfaceStyle": "light"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#10B981"
      },
      "package": "com.kingjayan.gradient",
      "minSdkVersion": 24,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "newArchEnabled": false
          },
          "android": {
            "minSdkVersion": 24,
            "targetSdkVersion": 34
          }
        }
      ],
      "expo-secure-store"
    ],
    "scheme": "gradient",
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    },
    "updates": {
      "enabled": false
    }
  }
}
